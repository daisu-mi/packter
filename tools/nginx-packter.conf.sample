# PACKTER broker — nginx reverse-proxy sample
# ---------------------------------------------------------------------------
# Drop-in for an already-running nginx:
#
#   sudo cp tools/nginx-packter.conf.sample /etc/nginx/conf.d/packter.conf
#   sudo $EDITOR /etc/nginx/conf.d/packter.conf     # set server_name + cert paths
#   sudo nginx -t && sudo systemctl reload nginx
#
# The default (Option A) is HTTPS and expects a TLS cert/key to already exist —
# `nginx -t` fails otherwise. No cert yet? Switch to Option B (plain HTTP).
#
# Files in /etc/nginx/conf.d/*.conf are included inside the http{} block by the
# stock nginx.conf, so the map / upstream / server blocks below are all in the
# right context. (The commented stream{} block at the very bottom is the one
# exception — see the note there.)
#
# The broker binds to 127.0.0.1:11300 (secure-by-default). Instead of exposing
# it directly with `--bind 0.0.0.0`, keep it on loopback and let nginx be the
# only public listener. nginx terminates the public connection (and TLS) and
# proxy_pass-es to the loopback broker.
#
# The broker serves BOTH on the same TCP port 11300:
#   - the static viewer + REST  ("/", "/config.json", ...)  -> plain HTTP
#   - the live feed             ("/ws")                      -> WebSocket
# so the proxy must forward the WebSocket Upgrade handshake as well.
# ---------------------------------------------------------------------------

# Map the Upgrade request header to the Connection response header:
#   - WebSocket request  (Upgrade: websocket)  -> Connection: upgrade
#   - ordinary HTTP request (no Upgrade)        -> Connection: close
# Without this, a plain proxy_pass would send "Connection: upgrade" on every
# request (or drop it), breaking either the static files or the socket.
#
# The variable is named $packter_connection_upgrade (not the common
# $connection_upgrade) on purpose: if your existing config already defines a
# map for another WebSocket app, a second map writing the SAME variable name is
# a fatal "duplicate map" error. A unique name lets this file drop in cleanly.
map $http_upgrade $packter_connection_upgrade {
    default upgrade;
    ''      close;
}

upstream packter_broker {
    server 127.0.0.1:11300;
    keepalive 16;
}

# ===========================================================================
# Option A (default) — HTTPS, TLS terminated at nginx. The viewer auto-selects
# wss:// (web/main.js derives the scheme from the page protocol). Plain :80 is
# redirected to :443 below.
#
# PREREQUISITE: the cert/key paths below must already exist, or `nginx -t` will
# fail ("cannot load certificate"). With certbot:
#   sudo certbot --nginx -d packter.example.org      # or: certonly, then set paths
# If you have no certs yet, comment this block out and use Option B (plain HTTP).
#
# Coexisting with existing vhosts: adding `listen 443 ssl` / `listen 80` here is
# NOT a duplicate-listen error even when nginx already serves other sites on
# those ports — that is exactly name-based virtual hosting, routed by
# server_name (HTTPS via SNI). The only hard conflicts are (a) a SECOND
# `default_server` on a port, which this block does not add, and (b) a
# server_name identical to an existing vhost (just use your own hostname).
# ===========================================================================
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    # HTTP/2 (optional). The standalone `http2 on;` directive needs nginx
    # 1.25.1+. On older nginx (e.g. Ubuntu 24.04 ships 1.24) it is instead
    # `listen 443 ssl http2;` on the listen lines above. Left off by default so
    # this file validates on any version; enable whichever your nginx supports:
    #   http2 on;                       # nginx >= 1.25.1
    server_name packter.example.org;   # <-- your hostname

    ssl_certificate     /etc/letsencrypt/live/packter.example.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/packter.example.org/privkey.pem;

    # On a box that already runs nginx, the stock site usually owns the default
    # server for :443/:80, so requests whose Host does not match server_name
    # above land there, not here. Reach PACKTER by the hostname you set above.
    # If this host is dedicated to PACKTER, make it the default and disable the
    # stock site:
    #     listen 443 ssl default_server;   # (and: rm /etc/nginx/sites-enabled/default)

    # Optional: gate the whole site behind HTTP basic auth, since the broker's
    # control messages (PACKTERMSG/HTML) are powerful. Generate the file with
    #   htpasswd -c /etc/nginx/packter.htpasswd alice
    # auth_basic           "PACKTER";
    # auth_basic_user_file /etc/nginx/packter.htpasswd;

    # The WebSocket endpoint needs the Upgrade dance + a long read timeout so
    # the idle persistent socket is not closed mid-stream.
    location = /ws {
        proxy_pass         http://packter_broker;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade    $http_upgrade;
        proxy_set_header   Connection $packter_connection_upgrade;
        proxy_set_header   Host       $host;
        proxy_set_header   X-Real-IP  $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 1h;     # the feed can be quiet for long stretches
        proxy_buffering    off;    # stream frames out immediately
    }

    # Everything else: the static viewer and REST, served by the broker.
    location / {
        proxy_pass       http://packter_broker;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

server {                           # redirect plain HTTP to HTTPS
    listen 80;
    listen [::]:80;
    server_name packter.example.org;
    return 301 https://$host$request_uri;
}

# ===========================================================================
# Option B — plain HTTP (no TLS), the viewer connects with ws://. Use this when
# you have no certificate (or terminate TLS elsewhere). Comment out Option A
# above (both server blocks) and uncomment this one.
# ===========================================================================
# server {
#     listen 80;
#     listen [::]:80;
#     server_name packter.example.org;   # <-- your hostname
#     # dedicated host? make it the default and drop the stock site:
#     #     listen 80 default_server;   # (and: rm /etc/nginx/sites-enabled/default)
#
#     location = /ws {
#         proxy_pass         http://packter_broker;
#         proxy_http_version 1.1;
#         proxy_set_header   Upgrade    $http_upgrade;
#         proxy_set_header   Connection $packter_connection_upgrade;
#         proxy_set_header   Host       $host;
#         proxy_set_header   X-Real-IP  $remote_addr;
#         proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
#         proxy_set_header   X-Forwarded-Proto $scheme;
#         proxy_read_timeout 1h;
#         proxy_buffering    off;
#     }
#     location / {
#         proxy_pass       http://packter_broker;
#         proxy_set_header Host              $host;
#         proxy_set_header X-Real-IP         $remote_addr;
#         proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
#         proxy_set_header X-Forwarded-Proto $scheme;
#     }
# }

# ---------------------------------------------------------------------------
# Note on the legacy UDP ingest (agents -> broker on UDP 11300): nginx's
# http{} block cannot proxy UDP, and `--bind` sets ONE address for both the UDP
# and TCP listeners — so a loopback broker also only accepts agent datagrams on
# loopback. If agents run on other hosts you therefore need one of:
#   - local agents only: leave everything on 127.0.0.1 (this sample as-is);
#   - bind the broker to the management IP (`--bind <mgmt-ip>`) so agents reach
#     UDP, and firewall TCP 11300 so only nginx (localhost) talks to it; or
#   - keep the broker fully on loopback and forward UDP with nginx's stream{}
#     module (below).
# The reverse proxy above is only for the viewer's HTTP/WebSocket traffic.
#
# IMPORTANT: stream{} is a TOP-LEVEL context, NOT inside http{} — so it CANNOT
# go in this conf.d file (which is included inside http{}; nginx would reject it
# with "stream directive is not allowed here"). Put it in the main
# /etc/nginx/nginx.conf at top level (and load ngx_stream_module if your build
# splits it out). For reference only:
#
#     stream {
#         server {
#             listen 11300 udp;
#             proxy_pass 127.0.0.1:11300;
#         }
#     }
# ---------------------------------------------------------------------------
